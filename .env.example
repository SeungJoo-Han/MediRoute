# ======================================================
# MediRoute 환경 설정 파일
# 이 파일을 복사해서 .env 로 저장 후 값을 채워주세요
# cp .env.example .env
# ======================================================

# REST API 키 (서버 사이드 geocoding, 장소 검색)
KAKAO_REST_API_KEY=여기에_카카오_REST_API_키_입력

# JavaScript 키 (브라우저 지도 표시)
KAKAO_JS_KEY=여기에_카카오_JS_키_입력

# ODsay 대중교통 API 키 (선택 사항, 없으면 추정값 사용)
ODSAY_API_KEY=

# 셔틀 정류장 최대 도보 거리 (미터, 기본값: 1500)
MAX_WALK_DISTANCE_METERS=1500
